$TTL    604800
@       IN      SOA     ns1.{{ bind9_internal_domain_name }}   admin.ns1.{{ bind9_internal_domain_name }}. (
                              3         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL

; name servers - NS records
  IN  NS  ns1.{{ bind9_internal_domain_name }}.

; name servers - A records
ns1.{{ bind9_internal_domain_name }}.  IN  A  {{ bind9_internal_ns1_ip }}
